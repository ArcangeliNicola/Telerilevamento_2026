getwd()
list.files()

#richiamo le bande utili
b16<-flip(rast("2016-08-14-00_00_2016-08-14-23_59_Sentinel-2_L1C_B02_(Raw).jpg"))
g16<-flip(rast("2016-08-14-00_00_2016-08-14-23_59_Sentinel-2_L1C_B03_(Raw).jpg"))
r16<-flip(rast("2016-08-14-00_00_2016-08-14-23_59_Sentinel-2_L1C_B04_(Raw).jpg"))
nir16<-flip(rast("2016-08-14-00_00_2016-08-14-23_59_Sentinel-2_L1C_B08_(Raw).jpg"))

b17<-flip(rast("2017-08-04-00_00_2017-08-04-23_59_Sentinel-2_L1C_B02_(Raw).jpg"))
g17<-flip(rast("2017-08-04-00_00_2017-08-04-23_59_Sentinel-2_L1C_B03_(Raw).jpg"))
r17<-flip(rast("2017-08-04-00_00_2017-08-04-23_59_Sentinel-2_L1C_B04_(Raw).jpg"))
nir17<-flip(rast("2017-08-04-00_00_2017-08-04-23_59_Sentinel-2_L1C_B08_(Raw).jpg"))

b25<-flip(rast("2025-08-09-00_00_2025-08-09-23_59_Sentinel-2_L1C_B02_(Raw).jpg"))
g25<-flip(rast("2025-08-09-00_00_2025-08-09-23_59_Sentinel-2_L1C_B03_(Raw).jpg"))
r25<-flip(rast("2025-08-09-00_00_2025-08-09-23_59_Sentinel-2_L1C_B04_(Raw).jpg"))
nir25<-flip(rast("2025-08-09-00_00_2025-08-09-23_59_Sentinel-2_L1C_B08_(Raw).jpg"))

#Creo stack
T16<-c(r16, g16, b16,nir16)
T17<-c(r17, g17, b17,nir17)
T25<-c(r25, g25, b25,nir25)

#Plot RGB con Red=NIR
im.multiframe(1,3)
im.plotRGB(T16, 4,2,3)
im.plotRGB(T17, 4,2,3)
im.plotRGB(T25, 4,2,3)

#DVI
dvi16<-im.dvi(T16,4,1)
dvi17<-im.dvi(T17,4,1)
dvi25<-im.dvi(T25,4,1)

im.multiframe(1,3)
plot(dvi16, col=viridis(100))
plot(dvi17, col=viridis(100))
plot(dvi25, col=viridis(100))

#NDVI
ndvi16<-im.ndvi(T16,4,1)
ndvi17<-im.ndvi(T17,4,1)
ndvi25<-im.ndvi(T25,4,1)

im.multiframe(1,3)
plot(ndvi16, col=inferno(100))
plot(ndvi17, col=inferno(100))
plot(ndvi25, col=inferno(100))










